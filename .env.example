# Copy to .env and fill in. Do not commit .env.

# Required for Expo app (npx expo start) – only EXPO_PUBLIC_* are loaded into the app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# For scripts (pull-races, etc.) and CI
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
